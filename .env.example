ENV=development
DATABASE_URL=sqlite:///./stocknews.db
SECRET_KEY=change_this_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
STRICT_SESSION_PLANS=premium,enterprise
PREMIUM_SESSION_POLICY=single_per_channel
LOGIN_OTP_MINUTES=10
LOGIN_OTP_MAX_ATTEMPTS=5
AUTH_DEBUG_OTP=false

SCAN_INTERVAL=20
TRIAL_DAYS=90
LEGAL_NOTICE_VERSION=2026-03

START_ENGINE_WORKER=true
START_REFERRAL_WORKER=true
START_SNAPSHOT_WORKER=false
START_AI_WORKER=true
AI_WORKER_INTERVAL=900
AI_WORKER_HISTORY_LIMIT=48
AI_WORKER_SNAPSHOT_STALE_SECONDS=900

INTERNAL_API_TOKEN=change_this_internal_token
API_BASE_URL=http://127.0.0.1:8000

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_USERNAME=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

CORS_ALLOWED_ORIGINS=https://www.stocknewsbr.com,https://stocknewsbr.com,http://localhost:3000,http://127.0.0.1:3000

MEDIA_UPLOAD_DIR=media
MEDIA_PUBLIC_PREFIX=/media
MEDIA_PUBLIC_BASE_URL=
MEDIA_MAX_MB=12

STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_REGION=auto
STORAGE_ENDPOINT_URL=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=
SIGNED_UPLOAD_EXPIRES=900

FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_FROM=no-reply@stocknewsbr.com
TELEGRAM_LINK_MINUTES=15

MODERATION_REPORT_THRESHOLD=4
MODERATION_POST_WINDOW_SECONDS=60
MODERATION_POST_WINDOW_LIMIT=12
MODERATION_BLOCKED_PHRASES=golpe,scam,spam
